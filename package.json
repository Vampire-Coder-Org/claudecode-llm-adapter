{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "claudecode-llm-adapter",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "claudecode-llm-adapter": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --compile --outfile ./dist/claudecode-llm-adapter",
    "build:mac-arm64": "bun build ./src/index.ts --compile --target=bun-darwin-arm64 --outfile ./dist/claudecode-llm-adapter-darwin-arm64",
    "build:mac-x64": "bun build ./src/index.ts --compile --target=bun-darwin-x64 --outfile ./dist/claudecode-llm-adapter-darwin-x64",
    "build:linux-x64": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile ./dist/claudecode-llm-adapter-linux-x64",
    "build:windows-x64": "bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile ./dist/claudecode-llm-adapter-windows-x64.exe"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@smithy/eventstream-codec": "4.2.14",
    "@smithy/util-utf8": "4.2.2",
    "aws4fetch": "1.0.20",
    "effect": "4.0.0-beta.83",
    "xdg-basedir": "5.1.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.9",
    "@types/bun": "1.3.13",
    "typescript": "^6.0.3"
  }
}
